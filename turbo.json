{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "AGENT_URL",
        "ANTHROPIC_API_KEY",
        "APP_URL",
        "ATTESTATION_REGISTRY_ADDRESS",
        "BOOTSTRAP_SECRET",
        "CDP_API_KEY_ID",
        "CDP_API_KEY_SECRET",
        "CDP_WALLET_SECRET",
        "DATABASE_URL",
        "DELEGATOR_PRIVATE_KEY",
        "FACILITATOR_PRIVATE_KEY",
        "FACILITATOR_URL",
        "MANDATE_FILE",
        "MANDATES_JSON",
        "PAY_TO_ADDRESS",
        "POLICY_MAX_AMOUNT_USDC",
        "PORT"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "db:push": {
      "cache": false,
      "env": ["DATABASE_URL"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
