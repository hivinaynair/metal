{
  "name": "@workspace/db",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "bun": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "bun": "./src/schema.ts",
      "default": "./dist/schema.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "db:push": "drizzle-kit push",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@workspace/typescript-config": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@t3-oss/env-core": "^0.13.11",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "zod": "^3.24.0"
  }
}
